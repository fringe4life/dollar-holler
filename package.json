{
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.5",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.14",
    "@fontsource/kalam": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@neondatabase/serverless": "^1.1.0",
    "@varlock/bitwarden-plugin": "^0.0.6",
    "arktype": "^2.2.0",
    "better-auth": "^1.6.5",
    "drizzle-orm": "beta",
    "elysia": "^1.4.28",
    "isomorphic-dompurify": "^3.9.0",
    "varlock": "^0.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/mcp": "^0.1.22",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@varlock/vite-integration": "^0.2.10",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "beta",
    "fallow": "^2.40.3",
    "mode-watcher": "^1.1.0",
    "openapi-types": "^12.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "ultracite": "7.6.0",
    "vite": "^8.0.8",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "name": "dollar-holler",
  "scripts": {
    "dev": "varlock run -- bun --bun vite dev",
    "build": "varlock run -- bun --bun vite build",
    "preview": "varlock run -- bun --bun vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "ultracite check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:seed": "varlock run -- bun ./src/lib/server/db/seed.ts",
    "db:clear": "bun ./src/lib/server/db/clear-app-data.ts",
    "db:generate": "varlock run -- bun x drizzle-kit generate",
    "db:migrate": "varlock run -- bun x drizzle-kit migrate",
    "db:studio": "varlock run -- bun x drizzle-kit studio",
    "db:push": "varlock run -- bun x drizzle-kit push",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter biome --agents cursor-cli --editors vscode --hooks cursor --frameworks svelte --quiet",
    "fix": "ultracite fix",
    "env:typegen": "varlock typegen",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:boundaries": "fallow list --boundaries",
    "fallow:boundary-violations": "fallow dead-code --boundary-violations"
  },
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "imports": {
    "#app.css": "./src/app.css"
  },
  "overrides": {
    "cookie": ">1.0.2",
    "uuid": ">=14.0.0"
  },
  "trustedDependencies": []
}
