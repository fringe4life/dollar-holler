{
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.20",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.15",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource/kalam": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/sveltekit": "^10.59.0",
    "@varlock/bitwarden-plugin": "^2.0.0",
    "arktype": "^2.2.1",
    "better-auth": "^1.6.20",
    "drizzle-orm": "1.0.0-rc.3",
    "elysia": "^1.4.29",
    "marked": "^18.0.5",
    "sanitize-html": "^2.17.5",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@ark-ui/svelte": "^5.22.1",
    "@biomejs/biome": "2.4.16",
    "@lucide/svelte": "^1.21.0",
    "@pandacss/dev": "^1.11.3",
    "@pandacss/plugin-svelte": "^1.11.3",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/mcp": "^0.1.24",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/bun": "^1.3.14",
    "@types/sanitize-html": "^2.16.1",
    "@varlock/vite-integration": "^1.2.0",
    "drizzle-kit": "1.0.0-rc.3",
    "openapi-types": "^12.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "varlock": "1.9.0",
    "vite": "^8.1.0",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "name": "dollar-holler",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "svelte-kit sync && panda codegen && panda cssgen && bun --bun vite build",
    "preview": "bun --bun vite preview",
    "prepare": "svelte-kit sync && panda codegen",
    "check": "ultracite check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:seed": "varlock run -- bun ./src/lib/server/db/seed.ts",
    "db:generate": "varlock run -- bun x drizzle-kit generate",
    "db:migrate": "varlock run -- bun x drizzle-kit migrate",
    "db:studio": "varlock run -- bun x drizzle-kit studio",
    "db:push": "varlock run -- bun x drizzle-kit push",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter biome --agents cursor-cli --editors vscode --hooks cursor --frameworks svelte --quiet",
    "fix": "ultracite fix",
    "env:typegen": "varlock typegen",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:boundaries": "fallow list --boundaries",
    "fallow:boundary-violations": "fallow dead-code --boundary-violations",
    "fallow:dupes": "fallow dupes"
  },
  "type": "module",
  "version": "0.9.0",
  "private": true,
  "overrides": {
    "cookie": ">1.0.2",
    "uuid": ">=14.0.0",
    "postcss": ">=8.5.10",
    "ip-address": ">10.1.0",
    "hono": ">=4.12.18",
    "fast-uri": ">3.1.1"
  },
  "trustedDependencies": []
}
