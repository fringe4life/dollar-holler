  },
  "devDependencies": {
    "@ark-ui/svelte": "^5.21.2",
    "@biomejs/biome": "2.4.14",
    "@lucide/svelte": "^1.14.0",
    "@pandacss/dev": "^1.11.1",
    "@pandacss/plugin-svelte": "^1.11.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/mcp": "^0.1.22",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/bun": "^1.3.13",
    "@varlock/vite-integration": "^1.1.1",
    "drizzle-kit": "1.0.0-rc.1",
    "fallow": "2.68.0",
    "openapi-types": "^12.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "ultracite": "7.6.3",
    "varlock": "^1.1.0",
    "vite": "^8.0.11",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "name": "dollar-holler",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "svelte-kit sync && panda codegen && bun --bun vite build",
    "preview": "bun --bun vite preview",
    "prepare": "svelte-kit sync && panda codegen",
    "check": "ultracite check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:seed": "bun ./src/lib/server/db/seed.ts",
    "db:generate": "bun x drizzle-kit generate",
    "db:migrate": "bun x drizzle-kit migrate",
    "db:studio": "bun x drizzle-kit studio",
    "db:push": "bun x drizzle-kit push",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter biome --agents cursor-cli --editors vscode --hooks cursor --frameworks svelte --quiet",
    "fix": "ultracite fix",
    "env:typegen": "varlock typegen",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:boundaries": "fallow list --boundaries",
    "fallow:boundary-violations": "fallow dead-code --boundary-violations",
    "fallow:dupes": "fallow dupes"
  },
  "type": "module",
  "version": "0.9.0",
  "private": true,
  "overrides": {
    "cookie": ">1.0.2",
    "uuid": ">=14.0.0",
    "postcss": ">=8.5.10",
    "ip-address": ">10.1.0",
    "hono": ">=4.12.16"
  },
  "trustedDependencies": []
}
