{
  "mcpServers": {
    "eslint": {
      "command": "npx",
      "args": ["@eslint/mcp@latest"],
      "env": {}
    },
    "Neon": {
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://mcp.neon.tech/mcp"]
    },
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp/coinnich/javascript-sveltekit"
    },
    "svelte-devtools": {
      "url": "http://localhost:5173/__svelte-devtools/mcp",
      "headers": {
        "x-svelte-devtools-token": "${env:SVELTE_DEVTOOLS_TOKEN}"
      }
    }
  }
}
