{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignoreDependencies": ["@varlock/bitwarden-plugin"],
  "rules": {
    "boundary-violation": "warn"
  },
  "duplicates": {
    "ignore": ["src/lib/server/db/schema.ts"]
  },
  "boundaries": {
    "zones": [
      {
        "name": "features-server",
        "patterns": ["src/lib/features/**/*.server.ts"]
      },
      { "name": "features", "patterns": ["src/lib/features/**"] },
      {
        "name": "server-db",
        "patterns": ["src/lib/server/db/**"]
      },
      { "name": "server", "patterns": ["src/lib/server/**"] },
      { "name": "components", "patterns": ["src/lib/components/**"] },
      { "name": "attachments", "patterns": ["src/lib/attachments/**"] },
      {
        "name": "shared",
        "patterns": [
          "src/lib/runes/**",
          "src/lib/stores/**",
          "src/lib/utils/**"
        ]
      },
      { "name": "routes", "patterns": ["src/routes/**", "src/hooks.server.ts"] }
    ],
    "rules": [
      {
        "from": "routes",
        "allow": [
          "features",
          "features-server",
          "components",
          "shared",
          "server",
          "server-db"
        ]
      },
      {
        "from": "features-server",
        "allow": [
          "features",
          "components",
          "shared",
          "attachments",
          "server-db",
          "server"
        ]
      },
      {
        "from": "features",
        "allow": [
          "components",
          "shared",
          "attachments",
          "server-db",
          "features-server"
        ]
      },
      {
        "from": "server",
        "allow": ["features", "features-server", "shared", "server-db"]
      },
      {
        "from": "components",
        "allow": ["features", "shared", "attachments"]
      },
      { "from": "attachments", "allow": ["shared"] },
      { "from": "shared", "allow": ["features"] }
    ]
  }
}
