{
  "name": "dollar-holler",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#app.css": "./src/app.css"
  },
  "scripts": {
    "dev": "varlock run -- bun --bun vite dev",
    "build": "varlock run -- bun --bun vite build",
    "preview": "varlock run -- bun --bun vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "ultracite check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --experimental-cli --write .",
    "lint": "prettier --experimental-cli --check . && eslint .",
    "lint:fix": "prettier --experimental-cli --write . && eslint . --fix",
    "db:seed": "varlock run -- bun ./src/lib/db/seed.ts",
    "db:clear": "bun ./src/lib/db/clear-app-data.ts",
    "db:generate": "varlock run -- bun x drizzle-kit generate",
    "db:migrate": "varlock run -- bun x drizzle-kit migrate",
    "db:studio": "varlock run -- bun x drizzle-kit studio",
    "db:push": "varlock run -- bun x drizzle-kit push",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter eslint --agents cursor-cli --editors vscode --hooks cursor --frameworks svelte --quiet",
    "fix": "ultracite fix",
    "env:typegen": "varlock typegen"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.0.0",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/mcp": "^0.1.22",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "beta",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-cypress": "^6.3.0",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-svelte": "^3.17.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "mode-watcher": "^1.1.0",
    "patch-package": "^8.0.1",
    "pg": "^8.20.0",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.7.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "ultracite": "7.5.6",
    "vite": "^8.0.8",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "overrides": {
    "@isaacs/brace-expansion": ">5.0.0",
    "esbuild": "^0.25.0",
    "cookie": "^1.0.2",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.1",
    "tar": ">7.5.10",
    "hono": ">=4.12.4",
    "lodash": ">4.17.22",
    "ajv": ">=8.18.0",
    "minimatch": ">=10.2.1",
    "rollup": ">=4.59.0",
    "storybook": "latest",
    "@hono/node-server": ">=1.19.10",
    "dompurify": ">3.3.1",
    "undici": ">=7.24.0",
    "flatted": ">3.4.1",
    "kysely": ">0.28.13",
    "yaml": ">=2.8.3",
    "brace-expansion": ">=5.0.5",
    "picomatch": ">=2.3.2",
    "defu": ">6.1.4"
  },
  "trustedDependencies": [],
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.14",
    "@fontsource/kalam": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@neondatabase/serverless": "^1.0.2",
    "@varlock/bitwarden-plugin": "^0.0.6",
    "@varlock/vite-integration": "^0.2.10",
    "arktype": "^2.2.0",
    "better-auth": "^1.6.2",
    "drizzle-orm": "beta",
    "elysia": "^1.4.28",
    "isomorphic-dompurify": "^3.8.0",
    "varlock": "^0.8.1"
  }
}